<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} — {% endif %}{{ site.gallery_name }}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}" />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            bg: '#FAFAFA',
            surface: '#FFFFFF',
            text: '#1A1A1A',
            primary: '#2C2C2C',
            secondary: '#737373',
          },
          fontFamily: {
            display: ['"Cormorant Garamond"', 'Georgia', 'serif'],
            body: ['Inter', 'system-ui', 'sans-serif'],
          },
        },
      },
    };
  </script>
  
  <style>
    /* Custom base styles */
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background-color: #FAFAFA;
      color: #1A1A1A;
    }
    .font-display {
      font-family: 'Cormorant Garamond', Georgia, serif;
    }
    
    /* Page transitions */
    html {
      opacity: 1;
      transition: opacity 0.3s ease;
    }
    
    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #FAFAFA;
    }
    ::-webkit-scrollbar-thumb {
      background: #737373;
      border-radius: 3px;
    }
    
    /* Hide scrollbar on mobile */
    @media (max-width: 768px) {
      ::-webkit-scrollbar {
        display: none;
      }
    }
    
    /* Focus states */
    :focus-visible {
      outline: 2px solid #2C2C2C;
      outline-offset: 2px;
    }
    
    /* Aspect ratio boxes for placeholders */
    .aspect-artwork {
      aspect-ratio: 3/4;
    }
    .aspect-hero {
      aspect-ratio: 16/9;
    }
    .aspect-square {
      aspect-ratio: 1/1;
    }
    
    /* Gradient placeholders matching original design */
    .gradient-placeholder-1 {
      background: linear-gradient(135deg, #E8E4E0 0%, #D4CFC8 50%, #C5BFB6 100%);
    }
    .gradient-placeholder-2 {
      background: linear-gradient(135deg, #E0DCD8 0%, #CEC9C2 50%, #BEB7AE 100%);
    }
    .gradient-placeholder-3 {
      background: linear-gradient(135deg, #D8D4D0 0%, #C4BFB8 50%, #B0A9A0 100%);
    }
    .gradient-placeholder-4 {
      background: linear-gradient(135deg, #E4E0DC 0%, #CCC7C0 50%, #B4ADA8 100%);
    }
  </style>
</head>
<body class="bg-bg font-body antialiased min-h-screen flex flex-col">
  
  {% include "nav.njk" %}
  
  <main class="flex-1">
    {{ content | safe }}
  </main>
  
  {% include "footer.njk" %}
  
  <!-- Mobile menu script -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuOverlay = document.getElementById('menu-overlay');
      
      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', function() {
          mobileMenu.classList.toggle('hidden');
          menuOverlay.classList.toggle('hidden');
          document.body.classList.toggle('overflow-hidden');
        });
        
        menuOverlay.addEventListener('click', function() {
          mobileMenu.classList.add('hidden');
          menuOverlay.classList.add('hidden');
          document.body.classList.remove('overflow-hidden');
        });
      }
      
      // Close mobile menu on escape
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          mobileMenu.classList.add('hidden');
          menuOverlay.classList.add('hidden');
          document.body.classList.remove('overflow-hidden');
        }
      });
    });
  </script>
</body>
</html>
