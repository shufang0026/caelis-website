---
layout: base.njk
title: Home
permalink: "/"
---

<!-- Hero Section -->
<section class="relative h-[70vh] lg:h-[85vh] overflow-hidden bg-surface">
  <div class="absolute inset-0 gradient-placeholder-1"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 p-8 lg:p-16">
    <div class="max-w-7xl mx-auto">
      <p class="text-white/80 text-xs tracking-widest uppercase mb-3">Current Exhibition</p>
      {% if currentExhibitions.length > 0 %}
      <h1 class="font-display text-4xl lg:text-6xl xl:text-7xl text-white font-light leading-tight mb-4">{{ currentExhibitions[0].data.title }}</h1>
      <p class="text-white/90 text-sm lg:text-base max-w-xl mb-6">{{ currentExhibitions[0].data.heroSubtitle }}</p>
      <a href="{{ currentExhibitions[0].url }}" class="inline-flex items-center text-white text-sm tracking-widest uppercase border-b border-white/50 pb-1 hover:border-white transition-colors">
        View Exhibition
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      {% else %}
      <h1 class="font-display text-4xl lg:text-6xl xl:text-7xl text-white font-light leading-tight mb-4">{{ site.gallery_name }}</h1>
      <p class="text-white/90 text-sm lg:text-base max-w-xl mb-6">{{ site.description }}</p>
      {% endif %}
    </div>
  </div>
</section>

<!-- Introduction -->
<section class="py-20 lg:py-32 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-display text-3xl lg:text-4xl font-light mb-8 text-text">A Space for Contemporary Dialogue</h2>
    <p class="text-base lg:text-lg leading-relaxed mb-6 text-secondary">Caelis Galeria is a contemporary art gallery based in Shanghai, dedicated to presenting thoughtful artistic practices and cross-cultural perspectives. We focus on contemporary visual expression, critical discourse, and experimental approaches within an international context.</p>
    <p class="text-base lg:text-lg leading-relaxed text-secondary">Through our curatorial program, we seek to create meaningful encounters between artworks, artists, and audiences—fostering conversations that transcend geographical and cultural boundaries.</p>
  </div>
</section>

<!-- Current Exhibitions Preview -->
<section class="py-16 lg:py-24 px-4 sm:px-6 lg:px-8 bg-surface">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-xs tracking-widest uppercase mb-2 text-secondary">Now Showing</p>
        <h2 class="font-display text-2xl lg:text-3xl font-light text-text">Current Exhibitions</h2>
      </div>
      <a href="/exhibitions/" class="hidden sm:flex items-center text-sm tracking-widest uppercase text-secondary hover:text-text transition-colors">
        View All
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      {% for exhibition in (currentExhibitions | limit(2)) %}
      <a href="{{ exhibition.url }}" class="exhibition-card group cursor-pointer block">
        <div class="aspect-[4/3] gradient-placeholder-{{ loop.index }} mb-6 bg-cover bg-center transition-transform duration-500 group-hover:scale-[1.02]"
          {% if exhibition.data.cover %}style="background-image: url({{ exhibition.data.cover }})"{% endif %}></div>
        <p class="text-xs tracking-widest uppercase mb-2 text-secondary">{{ exhibition.data.startDate | dateFormatShort }} — {{ exhibition.data.endDate | dateFormatShort }}</p>
        <h3 class="font-display text-xl lg:text-2xl font-light mb-3 text-text group-hover:text-primary transition-colors">{{ exhibition.data.title }}</h3>
        <p class="text-sm text-secondary">{{ exhibition.data.artists }}</p>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Art Insight Preview -->
<section class="py-16 lg:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-xs tracking-widest uppercase mb-2 text-secondary">From the Journal</p>
        <h2 class="font-display text-2xl lg:text-3xl font-light text-text">Art Insight</h2>
      </div>
      <a href="/art-insight/" class="hidden sm:flex items-center text-sm tracking-widest uppercase text-secondary hover:text-text transition-colors">
        Read More
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {% for article in (articles | limit(3)) %}
      <a href="{{ article.url }}" class="blog-card p-6 bg-surface hover:bg-gray-50 transition-colors cursor-pointer block">
        <p class="text-xs tracking-widest uppercase mb-4 text-secondary">{{ article.data.category }}</p>
        <h3 class="font-display text-lg lg:text-xl font-light mb-4 leading-snug text-text">{{ article.data.title }}</h3>
        <p class="text-sm text-secondary">{{ article.data.date | dateFormat }}</p>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Newsletter Subscribe -->
<section class="py-20 lg:py-28 px-4 sm:px-6 lg:px-8 bg-surface">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-display text-2xl lg:text-3xl font-light mb-3 text-text">Stay up-to-date on Caelis artists, exhibitions, and events.</h2>
    <p class="text-sm text-secondary mb-10">Subscribe to our newsletter for the latest updates.</p>
    <form action="#" method="POST" class="space-y-6" id="subscribe-form">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <input type="text" name="firstName" placeholder="First Name" required class="w-full bg-transparent border-b border-gray-300 pb-3 text-text placeholder:text-gray-400 focus:outline-none focus:border-text transition-colors text-base" />
        <input type="text" name="lastName" placeholder="Last Name" required class="w-full bg-transparent border-b border-gray-300 pb-3 text-text placeholder:text-gray-400 focus:outline-none focus:border-text transition-colors text-base" />
      </div>
      <input type="email" name="email" placeholder="Email" required class="w-full bg-transparent border-b border-gray-300 pb-3 text-text placeholder:text-gray-400 focus:outline-none focus:border-text transition-colors text-base" />
      <input type="text" name="country" placeholder="Country" required class="w-full bg-transparent border-b border-gray-300 pb-3 text-text placeholder:text-gray-400 focus:outline-none focus:border-text transition-colors text-base" />
      <button type="submit" class="mt-4 inline-flex items-center text-sm tracking-widest uppercase text-text border-b border-text/50 pb-1 hover:border-text transition-colors cursor-pointer bg-transparent">
        Subscribe
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </button>
    </form>
    <p id="subscribe-message" class="mt-6 text-sm hidden"></p>
  </div>
</section>
