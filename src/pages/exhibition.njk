---
layout: base.njk
title: "{{ title }}"
---

<article class="py-12 lg:py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <a href="/exhibitions/" class="inline-flex items-center text-sm tracking-widest uppercase mb-12 text-secondary hover:text-text transition-colors group">
      <svg class="mr-2 w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
      Back to Exhibitions
    </a>

    <header class="mb-12">
      <p class="text-xs tracking-widest uppercase mb-4 text-secondary">{{ startDate | dateFormatShort }} — {{ endDate | dateFormatShort }}</p>
      <h1 class="font-display text-4xl lg:text-5xl xl:text-6xl font-light mb-6 text-text">{{ title }}</h1>
      <p class="text-lg text-secondary">{{ artists }}</p>
    </header>

    <!-- Main Image -->
    <div class="aspect-[16/9] gradient-placeholder-1 mb-12 bg-cover bg-center"
      {% if cover %}style="background-image: url({{ cover }})"{% endif %}></div>

    <!-- Description + Details -->
    <div class="grid lg:grid-cols-3 gap-12 mb-16">
      <div class="lg:col-span-2">
        <div class="prose max-w-none">
          <p class="text-base leading-relaxed mb-6 text-text">{{ description }}</p>
          {{ content | safe }}
        </div>
      </div>
      <div>
        <div class="sticky top-32">
          <h3 class="text-xs tracking-widest uppercase mb-4 text-secondary">Exhibition Details</h3>
          <dl class="space-y-4">
            <div>
              <dt class="text-xs uppercase mb-1 text-secondary">Dates</dt>
              <dd class="text-sm text-text">{{ startDate | dateFormat }} — {{ endDate | dateFormat }}</dd>
            </div>

            <div>
              <dt class="text-xs uppercase mb-1 text-secondary">Curated by</dt>
              <dd class="text-sm text-text">{{ curator }}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase mb-1 text-secondary">Location</dt>
              <dd class="text-sm text-text">Shanghai, China</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>

    <!-- Gallery Carousel -->
    {% if gallery and gallery.length > 0 %}
    <div class="mb-16">
      <h2 class="text-xs tracking-widest uppercase mb-8 pb-4 border-b border-gray-200 text-secondary">Exhibition Views</h2>
      <div id="gallery-carousel" class="relative overflow-hidden rounded-sm">
        <div class="flex transition-transform duration-500 ease-out" id="gallery-track" style="width: {{ gallery.length * 100 }}%">
          {% for item in gallery %}
          <div class="flex-shrink-0 w-full" style="width: {{ 100 / gallery.length }}%">
            <div class="bg-black overflow-hidden flex items-center justify-center min-h-[300px] max-h-[85vh]">
              <img src="{{ item.path }}" alt="{{ item.caption }}" class="max-w-full max-h-[85vh] object-contain" loading="lazy" />
            </div>
            {% if item.caption %}
            <p class="text-xs text-secondary mt-3 text-center">{{ item.caption }}</p>
            {% endif %}
          </div>
          {% endfor %}
        </div>
        {% if gallery.length > 1 %}
        <button id="gallery-prev" class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 hover:bg-white rounded-full shadow flex items-center justify-center transition-opacity opacity-60 hover:opacity-100" aria-label="Previous">
          <svg class="w-5 h-5 text-text" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="gallery-next" class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 hover:bg-white rounded-full shadow flex items-center justify-center transition-opacity opacity-60 hover:opacity-100" aria-label="Next">
          <svg class="w-5 h-5 text-text" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
        </button>
        <div class="flex justify-center gap-2 mt-4" id="gallery-dots">
          {% for item in gallery %}
          <button class="gallery-dot w-2 h-2 rounded-full transition-colors {{ 'bg-text' if loop.first else 'bg-gray-300' }}" data-index="{{ loop.index0 }}" aria-label="Go to image {{ loop.index }}"></button>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    <!-- About Artist -->
    {% if artistSlug %}
    {% for a in artistProfiles %}
    {% if a.slug == artistSlug %}
    <div class="mb-16">
      <h2 class="text-xs tracking-widest uppercase mb-8 pb-4 border-b border-gray-200 text-secondary">About the Artist</h2>
      <div class="grid md:grid-cols-4 gap-8">
        {% if a.photo %}
        <div class="md:col-span-1">
          <div class="aspect-square bg-gray-100 overflow-hidden rounded-sm">
            <img src="{{ a.photo }}" alt="{{ a.name }}" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
        {% endif %}
        <div class="{{ 'md:col-span-3' if a.photo else 'md:col-span-4' }}">
          <h3 class="font-display text-2xl font-light mb-2 text-text">{{ a.name }}</h3>
          {% if a.style %}
          <p class="text-sm tracking-widest uppercase mb-6 text-secondary">{{ a.style }}</p>
          {% endif %}
          <div class="prose max-w-none">
            {% for paragraph in a.bio.split("\n\n") %}
            <p class="text-base leading-relaxed mb-4 text-text">{{ paragraph }}</p>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    {% endif %}
    {% endfor %}
    {% endif %}

    <!-- Artworks Grid -->
    {% if artworks and artworks.length > 0 %}
    <div>
      <h2 class="text-xs tracking-widest uppercase mb-8 pb-4 border-b border-gray-200 text-secondary">Selected Works</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for artwork in artworks %}
        <div>
          <div class="aspect-square gradient-placeholder-{{ (loop.index % 4) + 1 }} mb-4 bg-cover bg-center"
            {% if artwork.image %}style="background-image: url({{ artwork.image }})"{% endif %}></div>
          <p class="text-sm font-medium text-text">{{ artwork.title }}</p>
          <p class="text-xs text-secondary">{{ artwork.artist }}, {{ artwork.year }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <!-- Related Content -->
    <div class="mt-20 pt-10 border-t border-gray-200">
      <h2 class="text-xs tracking-widest uppercase mb-8 text-secondary">Related</h2>

      {# Related Exhibitions (same artist, exclude current) #}
      {% set relatedExhibitions = [] %}
      {% for ex in collections.exhibitions %}
        {% if ex.url != page.url and ex.data.artists and artists %}
          {% if ex.data.artists in artists or artists in ex.data.artists %}
            {% if relatedExhibitions.length < 3 %}
              {% set _ = relatedExhibitions.push(ex) %}
            {% endif %}
          {% endif %}
        {% endif %}
      {% endfor %}

      {# Related Articles (check if article mentions this exhibition's artists) #}
      {% set relatedArticles = [] %}
      {% for art in collections.articles %}
        {% if art.data.title != title and artists and art.data.title %}
          {% if artists in art.data.title %}
            {% if relatedArticles.length < 3 %}
              {% set _ = relatedArticles.push(art) %}
            {% endif %}
          {% endif %}
        {% endif %}
      {% endfor %}

      {% if relatedExhibitions.length > 0 or relatedArticles.length > 0 %}
      <div class="space-y-12">

        {# Related Exhibitions #}
        {% if relatedExhibitions.length > 0 %}
        <div>
          <p class="text-xs tracking-widest uppercase mb-4 text-secondary/70">Exhibitions</p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for ex in relatedExhibitions %}
            <a href="{{ ex.url }}" class="group block">
              {% if ex.data.cover %}
              <div class="aspect-[16/9] bg-gray-100 overflow-hidden rounded-sm mb-3">
                <img src="{{ ex.data.cover }}" alt="{{ ex.data.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              {% endif %}
              <p class="text-sm font-display text-text group-hover:underline leading-snug">{{ ex.data.title }}</p>
              <p class="text-xs text-secondary mt-1">{{ ex.data.artists }}</p>
            </a>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        {# Related Articles #}
        {% if relatedArticles.length > 0 %}
        <div>
          <p class="text-xs tracking-widest uppercase mb-4 text-secondary/70">Art Insight</p>
          <div class="space-y-4">
            {% for art in relatedArticles %}
            <a href="{{ art.url }}" class="group flex items-start gap-4">
              {% if art.data.cover %}
              <div class="w-24 h-16 flex-shrink-0 bg-gray-100 overflow-hidden rounded-sm">
                <img src="{{ art.data.cover }}" alt="" class="w-full h-full object-cover" loading="lazy" />
              </div>
              {% endif %}
              <div>
                <p class="text-sm font-display text-text group-hover:underline leading-snug">{{ art.data.title }}</p>
                <p class="text-xs text-secondary mt-1">{{ art.data.category }}</p>
              </div>
            </a>
            {% endfor %}
          </div>
        </div>
        {% endif %}

      </div>
      {% else %}
      <p class="text-sm text-secondary">Explore more on our <a href="/exhibitions/" class="underline hover:no-underline">Exhibitions</a> and <a href="/art-insight/" class="underline hover:no-underline">Art Insight</a> pages.</p>
      {% endif %}
    </div>
  </div>
</article>
