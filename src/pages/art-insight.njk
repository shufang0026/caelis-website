---
layout: base.njk
title: Art Insight
permalink: "/art-insight/"
---

<section class="py-16 lg:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-5xl mx-auto">
    <div class="mb-16">
      <h1 class="font-display text-4xl lg:text-5xl font-light mb-4 text-text">Art Insight</h1>
      <p class="text-base max-w-2xl text-secondary">Curatorial texts, critical essays, artist research, and extended exhibition content from Caelis Galeria.</p>
    </div>

    <div class="space-y-0">
      {% for article in collections.articles %}
      <a href="{{ article.url }}" class="blog-card flex flex-col md:flex-row md:items-start gap-4 md:gap-8 py-8 px-4 md:px-6 -mx-4 md:-mx-6 cursor-pointer border-b border-gray-200 hover:bg-gray-50 transition-colors">
        <div class="flex-1">
          <p class="text-xs tracking-widest uppercase mb-3 text-secondary">{{ article.data.category }}</p>
          <h2 class="font-display text-xl lg:text-2xl font-light mb-3 text-text">{{ article.data.title }}</h2>
          <p class="text-sm leading-relaxed mb-4 text-secondary">{{ article.data.excerpt }}</p>
          <p class="text-xs text-secondary">By {{ article.data.author }} &middot; {{ article.data.date | dateFormat }} &middot; {{ article.data.readTime }}</p>
        </div>
        <div class="w-full md:w-48 aspect-[4/3] gradient-placeholder-{{ (loop.index % 4) + 1 }} flex-shrink-0 bg-cover bg-center"
          {% if article.data.cover %}style="background-image: url({{ article.data.cover }})"{% endif %}></div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
