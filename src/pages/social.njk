---
layout: base.njk
title: Social
permalink: "/social/"
---

<section class="py-16 lg:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h1 class="font-display text-4xl lg:text-5xl font-light mb-4 text-text">Follow Our Journey</h1>
      <p class="text-base max-w-xl mx-auto mb-8 text-secondary">Stay connected with Caelis Galeria on Instagram for behind-the-scenes glimpses, exhibition previews, and moments from the gallery.</p>
      <a href="{{ site.instagram }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm tracking-widest uppercase border-b pb-1 text-text border-text hover:opacity-70 transition-opacity">
        @caelisgaleria
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>

    <!-- Instagram Grid -->
    <div class="grid grid-cols-3 md:grid-cols-4 gap-1">
      {% for i in range(1, 13) %}
      <div class="aspect-square gradient-placeholder-{{ (i % 4) + 1 }} relative group cursor-pointer overflow-hidden">
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300"></div>
      </div>
      {% endfor %}
    </div>

    <div class="text-center mt-12">
      <p class="text-sm mb-6 text-secondary">Note: For live Instagram integration, please connect your Instagram Business account through your website platform's social media settings.</p>
      <a href="{{ site.instagram }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-3 text-sm tracking-widest uppercase bg-primary text-surface transition-opacity hover:opacity-80">
        Follow on Instagram
      </a>
    </div>
  </div>
</section>
